function changeTicket(srcInput, destInput)
    local idSrc = getTicketID(srcInput)
    local idDest = getTicketID(destInput)

    if not idSrc or not idDest then
        gg.alert("تأكد من كتابة ارقام التصريح 🫠")
        return
    end
    gg.toast(" ❤️ صلي على النبي ❤️ ")
    gg.clearResults()
    gg.searchNumber("1634038552;1937011470;700~10000::121", gg.TYPE_DWORD, false, gg.SIGN_EQUAL, 0, -1)
    gg.refineNumber("700~1000", gg.TYPE_DWORD, false, gg.SIGN_EQUAL, 0, -1)
    
    local results = gg.getResults(100)
    local srcAddress = nil
    local destAddresses = {}

    for _, v in ipairs(results) do
        if v.value == idSrc and srcAddress == nil then srcAddress = v.address end
        if v.value == idDest then table.insert(destAddresses, v.address) end
    end

    if not srcAddress or #destAddresses == 0 then
        gg.alert("ارقام التصريح الذي ادخلتها خاطئة ❌️ ، راجع إرشادات التصريحات 📖")
        return
    end

    local sourceValues = {}
    for i = 0, 255 do
        sourceValues[i + 1] = {address = srcAddress - 0x1E8 + (i * 4), flags = gg.TYPE_DWORD}
    end
    
    local data = gg.getValues(sourceValues)
    
    local allTargetValues = {}
    for _, dAddr in ipairs(destAddresses) do
        for i = 0, 255 do
            table.insert(allTargetValues, {
                address = dAddr - 0x1E8 + (i * 4), 
                flags = gg.TYPE_DWORD, 
                value = data[i + 1].value
            })
        end
    end
    
    gg.setValues(allTargetValues)
    gg.clearResults()
    gg.alert("✅️ تم تبديل التصريح بنجاح!\n\n⚠️ يجب عليك إغلاق اللعبة وإعادة فتحها لمشاهدة التغييرات.")
    saveState("TICKET_MENU", "0")
    gg.setVisible(false)
end


function searchByName(defaultChoice, lastQuery)
    local userInput = lastQuery
    if not userInput then
        local input = gg.prompt({" أدخل اسم الشيء الذي تريده : "}, nil, {"text"})
        if not input or trim(input[1]) == "" then 
            mainMenu() 
            return 
        end
        userInput = trim(input[1]):lower()
    end
    
    local matches = {}
    for _, sect in ipairs(config) do 
        for _, item in ipairs(sect.items) do 
            if trim(item.name):lower():find(userInput) then table.insert(matches, {data = item, type = "U"}) end 
        end 
    end
    for _, item in ipairs(Decors) do
        if trim(item.Name):lower():find(userInput) then table.insert(matches, {data = item, type = "U"}) end
    end
    for k, cat in pairs(skins) do
        for _, item in ipairs(cat) do
            if trim(item.name):lower():find(userInput) then table.insert(matches, {data = {item = item, key = k}, type = "S"}) end
        end
    end
    
    if #matches == 0 then
        gg.alert("لا يوجد شيء بهذا الاسم ❌️")
        mainMenu()
    else
        local names = {"⬅️ عـــــــــــــــــــــــــــــــــــــــــــــودة", "🔍 البحث عن شيء آخر"}
        for _, m in ipairs(matches) do
            table.insert(names, m.data.name or m.data.Name or m.data.item.name)
        end
        table.insert(names, "🔍 البحث عن شيء آخر")
        table.insert(names, "⬅️ عـــــــــــــــــــــــــــــــــــــــــــــودة")
        
        saveState("SEARCH_MENU", userInput .. "|" .. tostring(defaultChoice or 1))
        
        local choice = gg.choice(names, tonumber(defaultChoice) or 3, "نتائج البحث التي تحتوي على: " .. userInput)

        
        if choice == nil then 
            gg.setVisible(false)
        elseif choice == 1 or choice == #names then 
            saveState("SEARCH_MENU", "0")
            mainMenu()
        elseif choice == 2 or choice == #names - 1 then
            saveState("SEARCH_MENU", "0")
            searchByName()
        else 
            saveState("SEARCH_MENU", userInput .. "|" .. tostring(choice))
            local sel = matches[choice - 2]
            if sel.type == "U" then applyUnified(sel.data)
            elseif sel.type == "S" then applySkins(sel.data.item, sel.data.key) end
            gg.setVisible(false)
        end
    end
end


