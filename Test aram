function savePointerResults(results)
    local f = io.open(stateFile, "w")
    if f then
        for _, r in ipairs(results) do
            f:write(tostring(r.address) .. "\n")
        end
        f:close()
    end
end

-- دالة تحميل النتائج
function loadPointerResults()
    local results = {}
    local f = io.open(stateFile, "r")
    if f then
        for line in f:lines() do
            table.insert(results, {address = tonumber(line), flags = 4})
        end
        f:close()
        return #results > 0 and results or nil
    end
