            if count == 0 then gg.alert("لم يتم العثور ع المؤشر الاساسي") return end
            cachedPointerResults = gg.getResults(count)
            savePointerResults(cachedPointerResults)
        end

        local editList, freezeList = {}, {}
        for _, r in ipairs(cachedGiftResults) do
            table.insert(freezeList, {address = r.address + 12, value = 2, flags = 4, freeze = true})
            for i = 0, 5 do table.insert(editList, {address = r.address + 16 + (i * 4), value = tableA[i+1], flags = 4}) end
            table.insert(editList, {address = r.address + 24, value = item.Level, flags = 4})
        end

        local codeCount = #item.Code
        for _, ptr in ipairs(cachedPointerResults) do
            for i = 0, codeCount - 1 do
