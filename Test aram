local stateFile = gg.EXT_CACHE_DIR .. "/last_state.txt"
os.remove(stateFile) 

function saveState(state, idx)
    local f = io.open(stateFile, "w")
    if f then 
        f:write(state .. "|" .. tostring(idx)) 
        f:close() 
    end
end

function loadState()
    local f = io.open(stateFile, "r")
    if f then
        local content = f:read("*a")
        f:close()
        local s, i = content:match("([^|]+)|(.+)")
        return s or "MAIN", i or "0"
    end
    return "MAIN", "0"
end


