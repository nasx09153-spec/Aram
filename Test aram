        gg.addListItems(freezeList)
        gg.alert("تم الاستبدال بنجاح ✅️\n\nاذهب واضغط ع الهدية 29 🎁")

    else
      local editList, freezeList = {}, {}
        for _, r in ipairs(cachedGiftResults) do
            local val = gg.getValues({{address = r.address + 12, flags = 4}})[1].value
            if val >= 0 and val <= 2 then
                table.insert(freezeList, {address = r.address + 12, value = 2, flags = 4, freeze = true})
                for j, h in ipairs(item.Code) do table.insert(editList, {address = r.address + 12 + (j * 4), value = h, flags = 4}) end
                table.insert(editList, {address = r.address + 40, value = 0, flags = 4})
                table.insert(editList, {address = r.address + 44, value = 1, flags = 4})
            end
        end
        gg.setValues(editList)
        gg.addListItems(freezeList)
        gg.alert("تم الاستبدال بنجاح ✅️\n\nاذهب واضغط ع الهدية 29 🎁")
    end
    gg.setVisible(false)
end


