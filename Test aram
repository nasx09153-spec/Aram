        if #cachedGiftResults == 0 then 
            gg.alert("لم يتم العثور على الهدية 29!") 
            return 
        end
    end

    if item.isPointer then
        if tableA == nil then
            gg.clearResults()
            gg.searchNumber("1768641320;1769105507;1634563187;1634882584;33;27::57", 4)
            gg.refineNumber("33", 4)
            local res = gg.getResults(1)
            if #res == 0 then gg.alert("لم يتم العثور ع كود استبدال المؤشر") return end
            tableA = {}
            for i = 0, 5 do table.insert(tableA, gg.getValues({{address = res[1].address + (i * 4), flags = 4}})[1].value) end
        end

        if cachedPointerResults == nil then
            cachedPointerResults = loadPointerResults()
        end
        
        if cachedPointerResults == nil then         
            gg.clearResults()
