        gg.setVisible(false) 
        local s, i = loadState()
        
        if s == "Z_MENU" then 
            local p1, p2 = i:match("([^|]+)|(.+)")
            local idx = tonumber(p1)
            if not p1 then idx = tonumber(i) end 
            if idx and config[idx] then
                zienaMenu(config[idx], idx, p2)
            else
                categoryMenu()
            end
     
        elseif s == "SKINS" then 
            skinsMenu(nil)

        elseif s == "SKINS_SUB" then 
            if i ~= "0" then
                local p1, p2 = i:match("([^|]+)|(.+)")
                skinsMenu(p1 or i, p2)
            else
                skinsMenu(nil)
            end

        elseif s == "SUB" then 
            local idx = tonumber(i)
            if idx and config[idx] then
                zienaMenu(config[idx], idx, nil)
            else
                mainMenu()
            end
            
        elseif s == "TICKET_MENU" then
            ticketMenu()
            
        elseif s == "PTR_MENU" then
            upgradableDecorsMenu(i ~= "0" and i or nil)

        elseif s == "CAT_SELECT" then
            categoryMenu()

        elseif s == "EVENT_MENU" then
            expEventMenu()

        elseif s == "SEARCH_MENU" then
            if i ~= "0" then
                local uInput, c = i:match("([^|]+)|(.+)")
                if uInput then searchByName(c, uInput) end
            else
                mainMenu()
            end

        else 
            mainMenu() 
        end
    end
    gg.sleep(200)
end
